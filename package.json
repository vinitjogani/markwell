{
  "name": "markwell",
  "displayName": "Markwell",
  "description": "A beautiful Notion-like markdown editor for VS Code & Cursor",
  "version": "0.2.2",
  "icon": "icon.png",
  "publisher": "vnj",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vinitjogani/markwell"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "markwell.markdownEditor",
        "displayName": "Markwell",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "markwell.revealInSource",
        "title": "Markwell: Reveal Selection in Source"
      },
      {
        "command": "markwell.print",
        "title": "Markwell: Print Document"
      },
      {
        "command": "markwell.formatBold",
        "title": "Markwell: Bold"
      },
      {
        "command": "markwell.formatItalic",
        "title": "Markwell: Italic"
      },
      {
        "command": "markwell.formatUnderline",
        "title": "Markwell: Underline"
      },
      {
        "command": "markwell.formatLink",
        "title": "Markwell: Add Link"
      }
    ],
    "keybindings": [
      {
        "command": "markwell.revealInSource",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p tsconfig.json",
    "build:webview": "node esbuild.mjs",
    "build": "npm run compile && npm run build:webview",
    "watch:ext": "tsc -p tsconfig.json --watch",
    "watch:webview": "node esbuild.mjs --watch",
    "dev": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "publish": "vsce publish && ovsx publish"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@tiptap/core": "^2.2.0",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/extension-subscript": "^2.27.2",
    "@tiptap/extension-superscript": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-typography": "^2.2.0",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/extension-youtube": "^2.27.2",
    "@tiptap/pm": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "@tiptap/suggestion": "^2.2.0",
    "emoji-picker-element": "^1.29.1",
    "katex": "^0.16.38",
    "markdown-it-footnote": "^4.0.0",
    "tiptap-markdown": "^0.8.10"
  },
  "license": "MIT"
}
